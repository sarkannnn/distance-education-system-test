# Database Credentials
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_username
DB_PASS=your_password
DB_CHARSET=utf8mb4

# TMIS Integration
TMIS_URL=https://tmis.ndu.edu.az
SSO_API_SECRET=your_sso_secret_here

# AI Chatbot API Keys
# Get Gemini key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Get OpenAI key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Metered.ca TURN Server (required for mobile/LTE connectivity)
# Sign up at https://www.metered.ca/stun-turn
METERED_API_KEY=your_metered_api_key_here
METERED_DOMAIN=your-app-name.metered.live

# LiveKit Server
# LIVEKIT_API_KEY and LIVEKIT_API_SECRET should already be set in your server environment.
# LIVEKIT_HOST=wss://distant-l.ndu.edu.az
# LIVEKIT_VERIFY_SSL=true
# PUBLIC_BASE_URL=https://your-domain.edu.az/distant-tehsil-test

# Egress Security — generate with: openssl rand -hex 32
EGRESS_SECRET_SALT=change-this-to-a-random-32-character-string